# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local SQLite database (do not commit)
*.db
*.db-journal
prisma/*.db
prisma/*.db-journal

# libSQL / SQLite local replica artifacts (do not commit)
/auth
/auth-wal
/auth-shm
/db
/db-wal
/db-shm

# screenshots / scratch images
สกรีนช็อต*.png
**/สกรีนช็อต*.png
*.jpg

.vercel
