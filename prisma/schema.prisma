generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== Branches (fixed only) ====================
model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  note      String   @default("")
  active    Boolean  @default(true)
  openedAt  DateTime @default(now())
  closedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          UserBranch[]
  menuOverrides  MenuItemBranch[]
  orders         Order[]
  shifts         Shift[]
  expenses       Expense[]
  inventoryItems InventoryItem[]
  promotions     Promotion[]
}

// ==================== Booth Events (popup / off-site events) ====================
model BoothEvent {
  id             String    @id @default(cuid())
  name           String
  location       String    @default("")
  note           String    @default("")
  status         String    @default("ACTIVE") // PLANNED | ACTIVE | CLOSED
  startDate      DateTime  @default(now())
  endDate        DateTime?
  cashIncome     Float     @default(0)
  transferIncome Float     @default(0)
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  shifts         Shift[]
  expenses       Expense[]
  inventoryItems InventoryItem[]
}

// ==================== Users & Auth ====================
model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      String   @default("STAFF") // ADMIN | MANAGER | STAFF
  // MANAGER per-menu access as JSON: {"income":"VIEW","staff":"EDIT",...}. Empty for ADMIN/STAFF.
  permissions String @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches    UserBranch[]
  shifts      Shift[]
  orders      Order[]
  attendances Attendance[]
}

model UserBranch {
  userId    String
  branchId  String
  isDefault Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
}

// ==================== Categories & Menu ====================
model Category {
  id        String     @id @default(cuid())
  name      String
  emoji     String     @default("")
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  price       Float
  shopeePrice Float    @default(0)
  image       String   @default("")
  description String   @default("")
  categoryId  String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]
  branchOverrides MenuItemBranch[]
}

model MenuItemBranch {
  menuItemId  String
  branchId    String
  price       Float?
  shopeePrice Float?
  active      Boolean?

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([menuItemId, branchId])
  @@index([branchId])
}

// ==================== Toppings ====================
model Topping {
  id        String   @id @default(cuid())
  name      String
  price     Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItemToppings OrderItemTopping[]
}

// ==================== Orders ====================
// Exactly one of branchId or boothEventId is set (app-level invariant).
model Order {
  id            String   @id @default(cuid())
  orderNumber   Int
  subTotal      Float
  discount      Float    @default(0)
  netTotal      Float
  paymentMethod String   @default("CASH")
  status        String   @default("COMPLETED")
  voidReason    String   @default("")
  channel       String   @default("DINE_IN")
  shopeeOrderId String   @default("")
  customerName  String   @default("")
  customerPhone String   @default("")
  branchId      String?
  boothEventId  String?
  staffId       String
  shiftId       String?
  promotionId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch?     @relation(fields: [branchId], references: [id])
  boothEvent BoothEvent? @relation(fields: [boothEventId], references: [id])
  staff      User        @relation(fields: [staffId], references: [id])
  shift      Shift?      @relation(fields: [shiftId], references: [id])
  promotion  Promotion?  @relation(fields: [promotionId], references: [id])
  items      OrderItem[]

  @@index([branchId])
  @@index([boothEventId])
  @@index([staffId])
  @@index([shiftId])
  @@index([createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  menuItemId     String
  menuItemName   String
  menuItemPrice  Float
  sweetnessLevel Int      @default(100)
  quantity       Int      @default(1)
  itemTotal      Float
  note           String   @default("")
  createdAt      DateTime @default(now())

  order    Order              @relation(fields: [orderId], references: [id])
  menuItem MenuItem           @relation(fields: [menuItemId], references: [id])
  toppings OrderItemTopping[]
}

model OrderItemTopping {
  id           String @id @default(cuid())
  orderItemId  String
  toppingId    String
  toppingName  String
  toppingPrice Float

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])
  topping   Topping   @relation(fields: [toppingId], references: [id])
}

// ==================== Shifts ====================
model Shift {
  id             String    @id @default(cuid())
  branchId       String?
  boothEventId   String?
  staffId        String
  openingCash    Float     @default(0)
  closingCash    Float?
  expectedCash   Float?
  cashDifference Float?
  note           String    @default("")
  status         String    @default("OPEN")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?

  branch     Branch?     @relation(fields: [branchId], references: [id])
  boothEvent BoothEvent? @relation(fields: [boothEventId], references: [id])
  staff      User        @relation(fields: [staffId], references: [id])
  orders     Order[]
  cashMovements CashMovement[]

  @@index([branchId])
  @@index([boothEventId])
}

// ==================== Attendance (time clock — independent of shifts) ====================
// One row per work session: clock in -> clock out. NOT tied to a branch/booth.
model Attendance {
  id            String    @id @default(cuid())
  staffId       String
  clockIn       DateTime  @default(now())
  clockOut      DateTime?
  status        String    @default("OPEN") // OPEN | CLOSED
  note          String    @default("")
  clockInPhoto  String    @default("") // photo URL captured at clock-in
  clockOutPhoto String    @default("") // photo URL captured at clock-out
  createdAt     DateTime  @default(now())

  staff User @relation(fields: [staffId], references: [id])

  @@index([staffId])
}

// ==================== Expenses ====================
model ExpenseCategory {
  id       String    @id @default(cuid())
  name     String
  color    String    @default("#6B7280")
  expenses Expense[]
}

model Expense {
  id           String   @id @default(cuid())
  branchId     String?
  boothEventId String?
  title        String
  amount       Float
  categoryId   String
  note         String   @default("")
  paidByOwner  Boolean  @default(false)
  recurring    Boolean  @default(false)
  slipUrl      String   @default("")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  branch     Branch?         @relation(fields: [branchId], references: [id])
  boothEvent BoothEvent?     @relation(fields: [boothEventId], references: [id])
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([branchId])
  @@index([boothEventId])
  @@index([date])
}

// ==================== Promotions ====================
model Promotion {
  id        String    @id @default(cuid())
  branchId  String?
  name      String
  type      String    @default("PERCENT")
  value     Float
  active    Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])
  orders Order[]

  @@index([branchId])
}

// ==================== Inventory (per branch OR per booth event) ====================
// Exactly one of branchId / boothEventId must be set (enforced at API level).
model InventoryItem {
  id            String   @id @default(cuid())
  branchId      String?
  boothEventId  String?
  name          String
  unit          String   @default("ชิ้น")
  quantity      Float    @default(0)
  minStock      Float    @default(0)
  costPrice     Float    @default(0)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch     Branch?     @relation(fields: [branchId], references: [id])
  boothEvent BoothEvent? @relation(fields: [boothEventId], references: [id])

  @@index([branchId])
  @@index([boothEventId])
}

// ==================== Cash Drawer Movements ====================
// Cash paid into / out of the drawer during a shift (pay-outs, drops, change
// fund). Feeds shift reconciliation so real shortages and normal pay-outs are
// distinguishable. Rolled out to prod via runtime ensure (see ensure-schema-extras.ts).
model CashMovement {
  id        String   @id @default(cuid())
  shiftId   String
  type      String   // IN | OUT
  amount    Float
  reason    String   @default("")
  staffId   String
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
}

// ==================== Activity / Audit Log ====================
// Append-only record of sensitive actions (voids, deletes, price/staff/setting
// changes). Best-effort — writing a log never blocks the underlying action.
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @default("")
  userName  String   @default("")
  action    String   // ORDER_VOID | ORDER_DELETE | MENU_UPDATE | SETTINGS_UPDATE ...
  entity    String   @default("")
  entityId  String   @default("")
  detail    String   @default("")
  branchId  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

// ==================== Settings (key-value) ====================
model Setting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
